{% apply footnotes_spaceless %}
  {# footnotes/footnote-links.html.twig #}
  {%- if footnote_links -%}
      {%- for footnote_link in footnote_links -%}
        {% if not loop.first %}
          <span class="footnote__citation-separator">, </span>
        {% endif %}
        {{ footnote_link }}
      {%- endfor -%}
  {%- endif -%}
{% endapply %}